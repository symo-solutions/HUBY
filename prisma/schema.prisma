// Schéma Prisma de Smart Ads Controller
//
// Le provider est SQLite pour un développement local sans infrastructure.
// Le schéma est volontairement portable : les énumérations sont stockées en
// String (validées côté application via lib/enums.ts) et les payloads JSON
// sont stockés en TEXT (voir lib/json-field.ts).
// Pour déployer sur PostgreSQL : passer `provider = "postgresql"` et
// relancer les migrations Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Authentification
// ---------------------------------------------------------------------------

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String?
  passwordHash   String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  adAccounts     AdAccount[]
  rules          AutomationRule[]
  logs           AutomationLog[]
}

// ---------------------------------------------------------------------------
// Intégrations publicitaires
// ---------------------------------------------------------------------------

model AdAccount {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform        String     // "META" | "GOOGLE" — voir lib/enums.ts
  externalId      String     // ex. act_1234 pour Meta, customers/123 pour Google
  name            String
  currency        String?    @default("EUR")

  // Tokens OAuth (à chiffrer au repos en production — cf. lib/crypto.ts)
  accessToken     String
  refreshToken   String?
  tokenExpiresAt  DateTime?

  connectedAt     DateTime   @default(now())
  lastSyncedAt    DateTime?

  campaigns       Campaign[]

  @@unique([userId, platform, externalId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Campagnes + métriques
// ---------------------------------------------------------------------------

model Campaign {
  id            String           @id @default(cuid())
  adAccountId   String
  adAccount     AdAccount        @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  externalId    String           // identifiant de la campagne côté plateforme
  name          String
  status        String           @default("UNKNOWN") // valeurs de CampaignStatus
  dailyBudget   Float?           // dans la devise du compte
  objective     String?

  // Métriques agrégées en cache (30 derniers jours) pour un tableau de bord rapide
  spend         Float            @default(0)
  impressions   Int              @default(0)
  clicks        Int              @default(0)
  conversions   Int              @default(0)
  revenue       Float            @default(0)
  roas          Float?           // revenu / dépense
  ctr           Float?           // clics / impressions

  flagged       Boolean          @default(false)
  flagReason    String?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  metrics       CampaignMetric[]
  logs          AutomationLog[]

  @@unique([adAccountId, externalId])
  @@index([adAccountId])
}

model CampaignMetric {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date         DateTime
  spend        Float    @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Int      @default(0)
  revenue      Float    @default(0)

  @@unique([campaignId, date])
  @@index([campaignId, date])
}

// ---------------------------------------------------------------------------
// Moteur de règles
// ---------------------------------------------------------------------------

model AutomationRule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String    // valeurs de RuleType — voir lib/enums.ts
  enabled     Boolean   @default(true)

  // Seuils ajustables (valeurs par défaut sensées côté application)
  threshold   Float?    // ex. 1,0 pour ROAS, 0,5 pour CTR (%)
  windowDays  Int?      @default(3)
  // Paramètres libres (ex. pourcentage d'augmentation de budget),
  // stockés en JSON sérialisé. Lecture/écriture via lib/json-field.ts.
  params      String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs        AutomationLog[]

  @@unique([userId, type])
  @@index([userId])
}

model AutomationLog {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  ruleId      String?
  rule        AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  campaignId  String?
  campaign    Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  action      String     // valeurs de LogAction
  status      String     @default("SUCCESS") // valeurs de LogStatus
  message     String
  // Métadonnées libres, stockées en JSON sérialisé. Voir lib/json-field.ts.
  metadata    String?

  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([campaignId])
}
