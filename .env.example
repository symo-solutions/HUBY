# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smart_ads_controller?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Meta Ads (Facebook) OAuth
# https://developers.facebook.com/apps
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/integrations/meta/callback"

# Google Ads OAuth
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
GOOGLE_ADS_DEVELOPER_TOKEN=""

# Cron security (used by /api/cron/sync)
CRON_SECRET="replace-with-a-cron-secret"

# Toggle mock data when API keys are absent
USE_MOCKS="true"

# OpenAI - powers the in-app AI agent chat (bottom-right bubble).
# Leave empty to use the built-in deterministic mock parser.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
