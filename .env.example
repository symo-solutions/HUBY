# Base de données
# En développement : SQLite local (file:./dev.db). En production : PostgreSQL.
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="remplacer-par-une-chaine-aleatoire-longue"

# OAuth Meta Ads (Facebook)
# https://developers.facebook.com/apps
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/integrations/meta/callback"

# OAuth Google Ads
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
GOOGLE_ADS_DEVELOPER_TOKEN=""

# Sécurité du cron (utilisé par /api/cron/sync)
CRON_SECRET="remplacer-par-un-secret-cron"

# Bascule sur les données simulées quand les clés API sont absentes
USE_MOCKS="true"

# OpenAI — alimente l'assistant IA intégré (bulle en bas à droite).
# Laisser vide pour utiliser le parseur déterministe de démonstration.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
